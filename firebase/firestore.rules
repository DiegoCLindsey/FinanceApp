// ==================== FIRESTORE SECURITY RULES ====================
// Desplegar en: Firebase Console → Firestore → Reglas
// O con Firebase CLI: firebase deploy --only firestore:rules
//
// MODELO DE SEGURIDAD:
//   1. Solo usuarios autenticados con email en /whitelist/{email} pueden acceder
//   2. Cada usuario solo puede leer/escribir SUS propios datos
//   3. La whitelist solo puede escribirla el administrador (consola de Firebase)
//   4. Los datos en Firestore están cifrados con AES-GCM en el cliente —
//      incluso con acceso de admin a la base de datos, no son legibles sin la passphrase
//
// GESTIÓN DE WHITELIST (como admin):
//   Firebase Console → Firestore → Colección "whitelist" → Añadir documento
//   Document ID = email del usuario (ej: "usuario@ejemplo.com")
//   Campos: { addedAt: <timestamp>, addedBy: "admin" }

rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Función de verificación de lista blanca
    function isWhitelisted() {
      return request.auth != null &&
             request.auth.token.email != null &&
             exists(/databases/$(database)/documents/whitelist/$(request.auth.token.email));
    }

    // Datos de usuario: solo accesibles por el propietario y si está en lista blanca
    match /users/{userId}/data/{document=**} {
      allow read, write:
        if request.auth != null
        && request.auth.uid == userId
        && isWhitelisted();
    }

    // Lista blanca: cada usuario puede leer solo su propio documento
    // (para verificar si tiene acceso autorizado)
    // Escritura: solo vía consola de Firebase (regla: false)
    match /whitelist/{email} {
      allow read:  if request.auth != null && request.auth.token.email == email;
      allow write: if false;
    }

    // Denegar todo lo demás explícitamente
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
